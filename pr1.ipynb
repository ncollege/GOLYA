# ============================================================
# Data Wrangling I using Python
# Dataset: Titanic Dataset
# Source: https://www.kaggle.com/datasets/yasserh/titanic-dataset
# ============================================================

# ============================================================
# STEP 1: Import Required Python Libraries
# ============================================================

# pandas -> used for data manipulation and analysis
import pandas as pd

# numpy -> used for numerical operations
import numpy as np

# sklearn -> used for normalization and encoding
from sklearn.preprocessing import MinMaxScaler
from sklearn.preprocessing import LabelEncoder

# ============================================================
# STEP 2: Load Open Source Dataset
# ============================================================

# Read CSV file using pandas
df = pd.read_csv("Titanic-Dataset.csv")

# Display first 5 rows
print("First 5 Rows of Dataset")
print(df.head())

# ============================================================
# STEP 3: Load Dataset into Pandas DataFrame
# ============================================================

print("\nDataset Loaded Successfully!")

# Display complete information about dataset
print("\nInformation about Dataset:")
print(df.info())

# ============================================================
# STEP 4: Data Preprocessing
# ============================================================

# ------------------------------------------------------------
# 4.1 Check Missing Values
# ------------------------------------------------------------

print("\nMissing Values in Dataset:")
print(df.isnull().sum())

# ------------------------------------------------------------
# 4.2 Statistical Summary
# ------------------------------------------------------------

print("\nStatistical Summary:")
print(df.describe())

# ------------------------------------------------------------
# 4.3 Variable Descriptions
# ------------------------------------------------------------

print("\nColumn Names:")
print(df.columns)

# ------------------------------------------------------------
# 4.4 Check Dimensions of Dataset
# ------------------------------------------------------------

print("\nShape of Dataset (Rows, Columns):")
print(df.shape)

# ------------------------------------------------------------
# 4.5 Display Data Types
# ------------------------------------------------------------

print("\nData Types of Each Column:")
print(df.dtypes)

# ============================================================
# STEP 5: Data Formatting and Normalization
# ============================================================

# ------------------------------------------------------------
# 5.1 Convert Data Types if Needed
# ------------------------------------------------------------

# Convert Survived column into category type
df['Survived'] = df['Survived'].astype('category')

# Convert Pclass into category type
df['Pclass'] = df['Pclass'].astype('category')

print("\nUpdated Data Types:")
print(df.dtypes)

# ------------------------------------------------------------
# 5.2 Handle Missing Values
# ------------------------------------------------------------

# Fill missing Age values with mean
df['Age'] = df['Age'].fillna(df['Age'].mean())

# Fill missing Embarked values with mode
df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])

# Fill missing Cabin values with 'Unknown'
df['Cabin'] = df['Cabin'].fillna("Unknown")

print("\nMissing Values After Handling:")
print(df.isnull().sum())

# ------------------------------------------------------------
# 5.3 Data Normalization
# ------------------------------------------------------------

# Normalize Age and Fare columns between 0 and 1

scaler = MinMaxScaler()

df[['Age', 'Fare']] = scaler.fit_transform(df[['Age', 'Fare']])

print("\nNormalized Data:")
print(df[['Age', 'Fare']].head())

# ============================================================
# STEP 6: Convert Categorical Variables into Quantitative
# ============================================================

# ------------------------------------------------------------
# Convert Sex Column
# ------------------------------------------------------------

label_encoder = LabelEncoder()

df['Sex'] = label_encoder.fit_transform(df['Sex'])

# male = 1
# female = 0

# ------------------------------------------------------------
# Convert Embarked Column
# ------------------------------------------------------------

df['Embarked'] = label_encoder.fit_transform(df['Embarked'])

print("\nDataset After Encoding:")
print(df.head())

# ============================================================
# Final Dataset Information
# ============================================================

print("\nFinal Dataset Information:")
print(df.info())

print("\nFinal Processed Dataset:")
print(df.head())

# ============================================================
# END OF PROGRAM
# ============================================================