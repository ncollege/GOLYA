# ============================================================
# DATA WRANGLING II
# ============================================================
# Aim:
# 1. Handle Missing Values and Inconsistencies
# 2. Detect and Handle Outliers
# 3. Apply Data Transformation
#
# Dataset Used:
# Titanic Dataset
# Source:
# https://www.kaggle.com/datasets/yasserh/titanic-dataset
# ============================================================

# ============================================================
# STEP 1: IMPORT REQUIRED LIBRARIES
# ============================================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# ============================================================
# STEP 2: LOAD DATASET
# ============================================================

df = pd.read_csv("Titanic-Dataset.csv")

print("First 5 Rows of Dataset")
print(df.head())

# ============================================================
# STEP 3: CHECK DATASET INFORMATION
# ============================================================

print("\nDataset Information")
print(df.info())

print("\nShape of Dataset")
print(df.shape)

# ============================================================
# STEP 4: CHECK MISSING VALUES
# ============================================================

print("\nMissing Values in Dataset")
print(df.isnull().sum())

# ============================================================
# STEP 5: HANDLE MISSING VALUES
# ============================================================

# Fill missing Age values using mean
df['Age'] = df['Age'].fillna(df['Age'].mean())

# Fill missing Embarked values using mode
df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])

# Fill missing Cabin values using 'Unknown'
df['Cabin'] = df['Cabin'].fillna('Unknown')

print("\nMissing Values After Handling")
print(df.isnull().sum())

# ============================================================
# STEP 6: CHECK FOR INCONSISTENCIES
# ============================================================

print("\nUnique Values in Sex Column")
print(df['Sex'].unique())

print("\nUnique Values in Embarked Column")
print(df['Embarked'].unique())

# Example inconsistency handling
# Convert all Sex values to lowercase

df['Sex'] = df['Sex'].str.lower()

print("\nUpdated Unique Values in Sex Column")
print(df['Sex'].unique())

# ============================================================
# STEP 7: DETECT OUTLIERS USING IQR METHOD
# ============================================================

# Detect Outliers in Fare Column

Q1 = df['Fare'].quantile(0.25)
Q3 = df['Fare'].quantile(0.75)

IQR = Q3 - Q1

lower_limit = Q1 - 1.5 * IQR
upper_limit = Q3 + 1.5 * IQR

print("\nLower Limit:", lower_limit)
print("Upper Limit:", upper_limit)

# Find outliers

outliers = df[(df['Fare'] < lower_limit) | (df['Fare'] > upper_limit)]

print("\nOutliers in Fare Column")
print(outliers[['Fare']])

print("\nNumber of Outliers:", len(outliers))

# ============================================================
# STEP 8: HANDLE OUTLIERS
# ============================================================

# Remove Outliers

df_no_outliers = df[
    (df['Fare'] >= lower_limit) &
    (df['Fare'] <= upper_limit)
]

print("\nShape Before Removing Outliers")
print(df.shape)

print("\nShape After Removing Outliers")
print(df_no_outliers.shape)

# ============================================================
# STEP 9: DATA TRANSFORMATION
# ============================================================

# Log Transformation on Fare Column
# Purpose:
# Reduce skewness and make distribution normal

df_no_outliers['Fare_Log'] = np.log1p(df_no_outliers['Fare'])

print("\nOriginal Fare Values")
print(df_no_outliers['Fare'].head())

print("\nLog Transformed Fare Values")
print(df_no_outliers['Fare_Log'].head())

# ============================================================
# STEP 10: VISUALIZATION
# ============================================================

# Histogram Before Transformation

plt.figure(figsize=(8,5))
plt.hist(df_no_outliers['Fare'], bins=30)
plt.title("Fare Distribution Before Transformation")
plt.xlabel("Fare")
plt.ylabel("Frequency")
plt.show()

# Histogram After Transformation

plt.figure(figsize=(8,5))
plt.hist(df_no_outliers['Fare_Log'], bins=30)
plt.title("Fare Distribution After Log Transformation")
plt.xlabel("Fare Log")
plt.ylabel("Frequency")
plt.show()

# ============================================================
# FINAL DATASET
# ============================================================

print("\nFinal Dataset")
print(df_no_outliers.head())

print("\nFinal Dataset Information")
print(df_no_outliers.info())

# ============================================================
# END OF PROGRAM
# ============================================================