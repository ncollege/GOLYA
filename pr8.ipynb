# ============================================================
# DATA VISUALIZATION I
# Histogram of Titanic Fare using Seaborn
# ============================================================

# Aim:
# Plot histogram to check distribution of ticket fare
# in Titanic dataset
# ============================================================

# ============================================================
# STEP 1: IMPORT LIBRARIES
# ============================================================

import seaborn as sns
import matplotlib.pyplot as plt

# ============================================================
# STEP 2: LOAD TITANIC DATASET
# ============================================================

# Load inbuilt Titanic dataset from seaborn

titanic = sns.load_dataset('titanic')

# Display first 5 rows
print("First 5 Rows")
print(titanic.head())

# ============================================================
# STEP 3: CHECK DATASET INFORMATION
# ============================================================

print("\nDataset Information")
print(titanic.info())

# ============================================================
# STEP 4: PLOT HISTOGRAM
# ============================================================

plt.figure(figsize=(8,5))

sns.histplot(titanic['fare'], bins=30)

plt.title("Distribution of Titanic Ticket Fare")

plt.xlabel("Fare")

plt.ylabel("Number of Passengers")

plt.show()

# ============================================================
# END OF PROGRAM
# ============================================================