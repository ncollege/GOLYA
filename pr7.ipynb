# ============================================================
# TEXT ANALYTICS
# ============================================================

# Aim:
# 1. Tokenization
# 2. POS Tagging
# 3. Stop Words Removal
# 4. Stemming
# 5. Lemmatization
# 6. TF-IDF Representation
# ============================================================

# ============================================================
# STEP 1: IMPORT LIBRARIES
# ============================================================

import nltk

# Download required nltk packages

nltk.download('punkt')
nltk.download('punkt_tab')
nltk.download('averaged_perceptron_tagger')
nltk.download('averaged_perceptron_tagger_eng')
nltk.download('stopwords')
nltk.download('wordnet')

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from nltk.stem import WordNetLemmatizer
from nltk import pos_tag

# TF-IDF
from sklearn.feature_extraction.text import TfidfVectorizer

# ============================================================
# STEP 2: SAMPLE DOCUMENT
# ============================================================

document = """
Data Analytics is the process of analyzing data
to get useful information. Machine Learning and
Artificial Intelligence are important technologies.
"""

print("Original Document:\n")
print(document)

# ============================================================
# STEP 3: TOKENIZATION
# ============================================================

tokens = word_tokenize(document)

print("\nTokens:\n")
print(tokens)

# ============================================================
# STEP 4: POS TAGGING
# ============================================================

pos = pos_tag(tokens)

print("\nPOS Tagging:\n")
print(pos)

# ============================================================
# STEP 5: STOP WORD REMOVAL
# ============================================================

stop_words = set(stopwords.words('english'))

filtered_words = []

for word in tokens:

    if word.lower() not in stop_words:

        filtered_words.append(word)

print("\nAfter Stop Word Removal:\n")
print(filtered_words)

# ============================================================
# STEP 6: STEMMING
# ============================================================

ps = PorterStemmer()

stemmed_words = []

for word in filtered_words:

    stemmed_words.append(ps.stem(word))

print("\nStemmed Words:\n")
print(stemmed_words)

# ============================================================
# STEP 7: LEMMATIZATION
# ============================================================

lemmatizer = WordNetLemmatizer()

lemmatized_words = []

for word in filtered_words:

    lemmatized_words.append(lemmatizer.lemmatize(word))

print("\nLemmatized Words:\n")
print(lemmatized_words)

# ============================================================
# STEP 8: TF-IDF
# ============================================================

documents = [document]

vectorizer = TfidfVectorizer()

tfidf = vectorizer.fit_transform(documents)

print("\nTF-IDF Feature Names:\n")
print(vectorizer.get_feature_names_out())

print("\nTF-IDF Values:\n")
print(tfidf.toarray())

# ============================================================
# END OF PROGRAM
# ============================================================