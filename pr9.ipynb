# ============================================================
# DATA VISUALIZATION II
# Box Plot of Age with respect to Gender and Survival
# ============================================================

# Aim:
# Plot boxplot for age distribution by gender
# and survival status in Titanic dataset
# ============================================================

# ============================================================
# STEP 1: IMPORT LIBRARIES
# ============================================================

import seaborn as sns
import matplotlib.pyplot as plt

# ============================================================
# STEP 2: LOAD TITANIC DATASET
# ============================================================

# Load inbuilt Titanic dataset
titanic = sns.load_dataset('titanic')

# Display first 5 rows
print("First 5 Rows")
print(titanic.head())

# ============================================================
# STEP 3: CHECK DATASET INFO
# ============================================================

print("\nDataset Information")
print(titanic.info())

# ============================================================
# STEP 4: PLOT BOXPLOT
# ============================================================

plt.figure(figsize=(10,6))

sns.boxplot(
    x='sex',
    y='age',
    hue='survived',
    data=titanic
)

plt.title("Age Distribution by Gender and Survival")

plt.xlabel("Gender")

plt.ylabel("Age")

plt.show()

# ============================================================
# END OF PROGRAM
# ============================================================