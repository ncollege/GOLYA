# ============================================================
# DATA VISUALIZATION III
# Iris Dataset Analysis
# ============================================================

# Aim:
# 1. Find features and their types
# 2. Create histogram for each feature
# 3. Create boxplot for each feature
# ============================================================

# ============================================================
# STEP 1: IMPORT LIBRARIES
# ============================================================

import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# ============================================================
# STEP 2: LOAD DATASET
# ============================================================

# Load Iris dataset from seaborn
iris = sns.load_dataset('iris')

# Display first 5 rows
print("First 5 Rows")
print(iris.head())

# ============================================================
# STEP 3: DATASET INFORMATION
# ============================================================

print("\nDataset Information")
print(iris.info())

print("\nShape of Dataset")
print(iris.shape)

print("\nColumn Names")
print(iris.columns)

# ============================================================
# STEP 4: FEATURES AND THEIR TYPES
# ============================================================

print("\nFeature Types")

print(iris.dtypes)

# ============================================================
# STEP 5: NUMBER OF FEATURES
# ============================================================

print("\nNumber of Features:")

print(len(iris.columns))

# ============================================================
# STEP 6: HISTOGRAM FOR EACH FEATURE
# ============================================================

# Histogram for all numeric columns

iris.hist(figsize=(10,8))

plt.suptitle("Histogram of Iris Features")

plt.show()

# ============================================================
# STEP 7: BOXPLOT FOR EACH FEATURE
# ============================================================

plt.figure(figsize=(12,6))

# Boxplot for all numeric columns

sns.boxplot(data=iris)

plt.title("Boxplot of Iris Features")

plt.show()

# ============================================================
# END OF PROGRAM
# ============================================================